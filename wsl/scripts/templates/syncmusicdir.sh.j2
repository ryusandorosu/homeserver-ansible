#!/bin/bash
if ping -c1 {{ wireguard_devices.phone.ip }}; then
#update: to skip newer files on receiver to be replaced
rsync \
  --dry-run \
  --stats \
  --itemize-changes \
  --log-file='{{ musictools }}/log/rsynclog_${{ customlog_datefile }}.log' \
  --archive \
  --update \
  --delete \
  --mkpath \
{% for pattern in excludepatterns %}
  --filter='exclude {{ pattern }}' \
{% endfor %}
  /mnt/d/Music/ \
  redmi:{{ default_termux_path }}Music/
fi

