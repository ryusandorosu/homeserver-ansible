{% import "macros/mihomo.j2" as imported %}
apiVersion: 1

groups:
  - name: {{ docker.mihomo }}
    folder: alerts
    interval: {{ mihomo_alerts.interval }}
    rules:
{% for key, rule in mihomo_metrics.items() %}
      - uid: {{ key }}
        title: {{ rule.alert.title }}
        data:
          - refId: {{ rule.draw.ref }}
            relativeTimeRange:
              from: {{ mihomo_alerts.seek_period | regex_replace('m', '') | int * 60 }}
              to: 0
            datasourceUid: {{ loki_uid }}
            model:
{% if rule.query.method == 'count' %}
              expr: >
                {{ imported.mihomo_loki_query(rule, docker.mihomo, mihomo_alerts.seek_period) | indent(16) }}{% if rule.query.type == 'instant' %} {{ rule.condition.operator }} {{ rule.condition.value }}
{% endif %}

{% endif %}
              instant: true
              intervalMs: 1000
              maxDataPoints: 43200
              queryType: {{ rule.query.type }}
              refId: {{ rule.draw.ref }}
{% if rule.query.type == 'range' %}
          - refId: {{ mihomo_alerts.ref.reduce }}
            datasourceUid: __expr__
            model:
              conditions:
                  - evaluator:
                      params:
                          - 0
                          - 0
                      type: gt
                    operator:
                      type: and
                    query:
                      params: []
                    reducer:
                      params: []
                      type: avg
                    type: query
              datasource:
                  name: Expression
                  type: __expr__
                  uid: __expr__
              expression: {{ rule.draw.ref }}
              intervalMs: 1000
              maxDataPoints: 43200
              reducer: last
              refId: {{ mihomo_alerts.ref.reduce }}
              type: reduce
          - refId: {{ mihomo_alerts.ref.condition }}
            datasourceUid: __expr__
            model:
              conditions:
                  - evaluator:
                      params:
                          - {{ rule.condition.value }}
                          - 0
                      type: {% if rule.condition.operator == '>' %}gt
{% elif rule.condition.operator == '==' %}eq
{% endif %}
                    operator:
                      type: and
                    query:
                      params: []
                    reducer:
                      params: []
                      type: avg
                    type: query
              datasource:
                  name: Expression
                  type: __expr__
                  uid: __expr__
              expression: {{ mihomo_alerts.ref.reduce }}
              intervalMs: 1000
              maxDataPoints: 43200
              refId: {{ mihomo_alerts.ref.condition }}
              type: threshold
{% endif %}
        condition: {% if rule.query.type == 'instant' %}{{ rule.draw.ref }}
{% elif rule.query.type == 'range' %}{{ mihomo_alerts.ref.condition }}
{% endif %}
        for: {{ mihomo_alerts.pending_period }}
        dashboardUid: {{ mihomo_dashboard_link.uid }}
        panelId: "{{ mihomo_dashboard_link.panel_id }}"
        annotations:
          description: "{{ rule.alert.description }}"
          threshold: "{{ rule.condition.operator }} {{ rule.condition.value }}"
          __dashboardUid__: {{ mihomo_dashboard_link.uid }}
          __panelId__: "{{ mihomo_dashboard_link.panel_id }}"
          __alertUid__: {{ key }}
        labels:
          severity: {{ rule.alert.severity }}
{% if rule.query.type == 'instant' %}
        noDataState: OK
        execErrState: Error
{% endif %}
{% endfor %}
