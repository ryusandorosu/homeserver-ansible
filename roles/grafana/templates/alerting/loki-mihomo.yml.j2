{% import "macros/mihomo.j2" as imported %}
apiVersion: 1

groups:
  - name: {{ docker.mihomo }}
    folder: alerts
    interval: {{ mihomo_alerts.interval }}
    rules:
{% for key, rule in mihomo_metrics.items() %}
{% set reduce_refid = key + '_value' %}
{% set condition_refid = key + '_condition' %}
      - uid: {{ key }}
        title: {{ rule.alert.title }}
        data:
          - refId: {{ key }}
            relativeTimeRange:
              from: {{ mihomo_alerts.seek_period | regex_replace('m', '') | int * 60 }}
              to: 0
            datasourceUid: {{ loki_uid }}
            model:
{% if rule.query.method == 'count' %}
              expr: >
                {{ imported.mihomo_loki_query(rule, docker.mihomo, mihomo_alerts.seek_period) | indent(16) }}{% if rule.query.type == 'instant' %} {{ rule.condition.operator }} {{ rule.condition.value }}
{% endif %}

{% endif %}
              instant: true
              intervalMs: 1000
              maxDataPoints: 43200
              queryType: {{ rule.query.type }}
              refId: {{ key }}
{% if rule.query.type == 'range' %}
          - refId: {{ reduce_refid }}
            datasourceUid: __expr__
            model:
              conditions:
                  - evaluator:
                      params:
                          - 0
                          - 0
                      type: gt
                    operator:
                      type: and
                    query:
                      params: []
                    reducer:
                      params: []
                      type: avg
                    type: query
              datasource:
                  name: Expression
                  type: __expr__
                  uid: __expr__
              expression: {{ key }}
              intervalMs: 1000
              maxDataPoints: 43200
              reducer: last
              refId: {{ reduce_refid }}
              type: reduce
          - refId: {{ condition_refid }}
            datasourceUid: __expr__
            model:
              conditions:
                  - evaluator:
                      params:
                          - {{ rule.condition.value }}
                          - 0
                      type: {% if rule.condition.operator == '>' %}gt
{% elif rule.condition.operator == '<' %}lt
{% elif rule.condition.operator == '==' %}eq
{% elif rule.condition.operator == '!=' %}ne
{% elif rule.condition.operator == '>=' %}gte
{% elif rule.condition.operator == '<=' %}lte
{% endif %}
                    operator:
                      type: and
                    query:
                      params: []
                    reducer:
                      params: []
                      type: avg
                    type: query
              datasource:
                  name: Expression
                  type: __expr__
                  uid: __expr__
              expression: {{ reduce_refid }}
              intervalMs: 1000
              maxDataPoints: 43200
              refId: {{ condition_refid }}
              type: threshold
{% endif %}
        condition: {% if rule.query.type == 'instant' %}{{ key }}
{% elif rule.query.type == 'range' %}{{ condition_refid }}
{% endif %}
        for: {{ mihomo_alerts.pending_period }}
        dashboardUid: {{ mihomo_dashboard_link.uid }}
        panelId: "{{ mihomo_dashboard_link.panel_id.normal }}"
        annotations:
          description: "{{ rule.alert.description }}"
          threshold: "{{ rule.condition.operator }} {{ rule.condition.value }}"
          alertname: "{{ rule.alert.title }}"{# possibly not needed #}
          __dashboardUid__: {{ mihomo_dashboard_link.uid }}
          __panelId__: "{{ mihomo_dashboard_link.panel_id.normal }}"
          __alertUid__: {{ key }}
        labels:
          severity: {{ rule.alert.severity }}
{% if rule.query.type == 'instant' %}
        noDataState: OK
        execErrState: Error
{% endif %}
{% endfor %}
