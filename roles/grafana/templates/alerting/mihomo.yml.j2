apiVersion: 1

groups:
  - name: {{ docker.mihomo }}
    folder: alerts
    interval: {{ interval }}
    rules:
{% for key, rule in mihomo_alert.items() %}
      - uid: {{ key }}
        title: {{ rule.title }}
        data:
          - refId: A
            relativeTimeRange:
              from: {{ seek_period | regex_replace('m', '') | int * 60 }}
              to: 0
            datasourceUid: {% if rule.datasource == 'loki' %}{{ loki_uid }}
{% elif rule.datasource == 'prometheus' %}{{ prometheus_uid }}
{% endif %}
            model:
{% if rule.query.method == 'count' %}
              expr: >
                count_over_time(
                  {container="/{{ docker.mihomo }}"}
                  |{% if rule.query.mode == 'exact' %}={% elif rule.query.mode == 'regex' %}~{% endif %} "{{ rule.query.match }}"
                  [{{ seek_period }}]
                ){% if rule.query.type == 'instant' %} {{ rule.condition.operator }} {{ rule.condition.value }}
{% endif %}

{% endif %}
              instant: true
              intervalMs: 1000
              maxDataPoints: 43200
              queryType: {{ rule.query.type }}
              refId: A
{% if rule.query.type == 'range' %}
          - refId: B
            datasourceUid: __expr__
            model:
              conditions:
                  - evaluator:
                      params:
                          - 0
                          - 0
                      type: gt
                    operator:
                      type: and
                    query:
                      params: []
                    reducer:
                      params: []
                      type: avg
                    type: query
              datasource:
                  name: Expression
                  type: __expr__
                  uid: __expr__
              expression: A
              intervalMs: 1000
              maxDataPoints: 43200
              reducer: last
              refId: B
              type: reduce
          - refId: C
            datasourceUid: __expr__
            model:
              conditions:
                  - evaluator:
                      params:
                          - {{ rule.condition.value }}
                          - 0
                      type: {% if rule.condition.operator == '>' %}gt
{% elif rule.condition.operator == '==' %}eq
{% endif %}
                    operator:
                      type: and
                    query:
                      params: []
                    reducer:
                      params: []
                      type: avg
                    type: query
              datasource:
                  name: Expression
                  type: __expr__
                  uid: __expr__
              expression: B
              intervalMs: 1000
              maxDataPoints: 43200
              refId: C
              type: threshold
{% endif %}
        condition: {% if rule.query.type == 'instant' %}A
{% elif rule.query.type == 'range' %}C
{% endif %}
        for: {{ pending_period }}
        annotations:
          description: "{{ rule.description }}"
          threshold: "{{ rule.condition.operator }} {{ rule.condition.value }}"
        labels:
          alert_uid: {{ key }}
          severity: {{ rule.severity }}
{% if rule.query.type == 'instant' %}
        noDataState: OK
        execErrState: Error
{% endif %}
{% endfor %}
