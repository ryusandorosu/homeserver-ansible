{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
{% for key, unit in promtail_systemd.items() %}
    {
      "type": "logs",
      "title": "{{ unit.name }} Log",
      "targets": [
        {
          "expr": "{job=\"systemd\", unit=\"{{ key }}.service\"}",
          "refId": "{{ loop.index }}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": {{ 0 + (loop.index0 * 8) }}
      }
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["loki"],
  "templating": {
    "list": []
  },
  "title": "Loki logs: journalctl",
  "version": 1
}