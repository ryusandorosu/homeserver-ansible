{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
{% for key, panel in nginx_dashboard.items() %}
    {
      "type": "{{ panel.type }}",
      "title": "{{ panel.title }}",
      "targets": [
        {
          "expr": {{ panel.expr | to_json }},
{% if panel.label is defined %}
          "legendFormat": "{% raw %}{{ {% endraw %}{{ panel.label }} }}",
{% endif %}
          "refId": "{{ loop.index }}"
        }
      ],
{% if panel.type == "logs" %}
      "options": {
        "fontSize": "small",
        "showControls": true
      },
{% elif panel.type == "heatmap" %}
      "options": {
        "calculate": false
      },
{% elif panel.type == "timeseries" %}
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars"
          },
          "stacking": {
            "mode": "normal"
          }
        }
      },
{% elif panel.type == "barchart" %}
      "options": {
        "barWidth": 1,
        "groupWidth": 1,
        "fullHighlight": false,
        "xTickLabelSpacing": 100
      },
{% endif %}
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": {{ 0 + (loop.index0 * 8) }}
      }
    }{% if not loop.last %},
{% endif %}
{% endfor %}

  ],
  "refresh": "{{ refresh_time }}",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["loki", "nginx"],
  "templating": {
    "list": [
{% for label, cfg in nginx_labels.items() %}
      {
        "name": "{{ label }}",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "{{ loki_uid }}"
        },
{% if cfg.default is defined %}
        "current": {
          "text": [
            "{{ cfg.default }}"
          ],
          "value": [
            "{{ cfg.default }}"
          ]
        },
{% endif %}
        "includeAll": true,
        "multi": true,
        "query": "label_values({job=\"{{ promtail_logs.nginx_access.name }}\"}, {{ label }})"
      }{% if not loop.last %},
{% endif %}
{% endfor %}

    ]
  },
  "title": "Loki: Nginx Logs & Monitoring",
  "version": 1
}