{% set panelHeight = 6 %}
{% set loopPanelHeight = 8 %}
{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "type": "logs",
      "title": "{{ promtail_logs.fail2ban_logs.path }}",
      "targets": [
        {
          "expr": "{job=\"{{ promtail_logs.fail2ban_logs.name }}\"}",
          "refId": "mainlog"
        }
      ],
      "options": {
        "fontSize": "small",
        "showControls": true
      },
      "gridPos": {
        "h": {{ panelHeight }},
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
{% for key, panel in f2b_dashboard.items() %}
    {
      "type": "{{ panel.type }}",
      "title": "{{ panel.title }}",
      "targets": [
        {
          "expr": {{ panel.expr | to_json }},
{% if panel.label is defined %}
          "legendFormat": "{% raw %}{{ {% endraw %}{{ panel.label }} }}",
{% endif %}
          "refId": "{{ loop.index }}"
        }
      ],
{% if panel.type == "logs" %}
      "options": {
        "fontSize": "small",
        "showControls": true{% if panel.json is defined %},
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "showLabels": false,
        "showTime": true,
        "syntaxHighlighting": true
{% endif %}
      },
{% elif panel.type == "barchart" %}
      "options": {
        "barWidth": 1,
        "groupWidth": 1,
        "fullHighlight": false,
        "xTickLabelSpacing": 100
      },
{% endif %}
      "gridPos": {
        "h": {{ loopPanelHeight }},
        "w": 24,
        "x": 0,
        "y": {{ panelHeight + (loop.index0 * loopPanelHeight) }}
      }
    }{% if not loop.last %},
{% endif %}
{% endfor %}

  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "loki",
    "fail2ban"
  ],
  "templating": {
    "list": [
{% for label in f2b_labels %}
      {
        "name": "{{ label }}",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "{{ loki_uid }}"
        },
        "includeAll": true,
        "multi": true,
        "query": "label_values({job=\"{{ promtail_logs.fail2ban_events.name }}\"}, {{ label }})"
      }{% if not loop.last %},
{% endif %}
{% endfor %}

    ]
  },
  "time": {
    "from": "now-{{ f2b_event_dashboard.showtime }}",
    "to": "now"
  },
  "title": "Loki: Fail2Ban Ban Events - Logs & Monitoring",
  "uid": "{{ f2b_event_dashboard.uid }}",
  "version": 1
}