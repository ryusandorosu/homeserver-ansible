server {

    listen {{ https_port }} ssl;
    server_name {{ item }};

    {{ lookup('template', 'modules/common.j2') | indent(4) }}
    access_log /var/log/nginx/{{ item }}_access.log main;

    root {{ item.root | default('/var/www/html') }};
{% if item.root | default('/var/www/html') == '/var/www/html' %}
    index index.nginx-debian.html;
{% else %}
    index {{ item.index }};
{% endif %}

    location / {
        limit_req zone=global burst=20 nodelay;
    }

}
