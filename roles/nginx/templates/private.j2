server {

    listen {{ https_port }} ssl;
    server_name {{ item.key }}.{{ domain }};

    {{ lookup('template', 'modules/common.j2') | indent(4) }}
    access_log /var/log/nginx/{{ item.key }}.{{ domain }}_access.log main;
    {{ lookup('template', 'modules/private.j2') | indent(4) }}
    {{ lookup('template', 'modules/authentication.j2') | indent(4) }}
{% if item.key != 'auth' %}
    location / {

{% if item.value.authentication %}
{% if nginx_authentication == 'basic_auth' %}
        auth_basic "Restricted";
        auth_basic_user_file {{ nginx_basic_auth_path }};
{% elif nginx_authentication == 'oauth' %}
        auth_request /oauth2/auth;
        error_page 401 =302 {{ nginx_hosts.auth }}/oauth2/sign_in?rd=$scheme://$host$request_uri;
{% elif nginx_authentication == 'authelia' %}
        auth_request /api/verify;
        error_page 401 =302 {{ nginx_hosts.auth }}/?rd=$scheme://$host$request_uri;
{% endif %}

{% endif %}
        proxy_pass {{ item.value.proto }}://{{ localhost }}:{{ item.value.port }}{% if item.key == 'guac' %}/guacamole/{% endif %};

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
{% if item.value.proto == 'http' %}
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;{# {% if item.key != 'guac' %} #}

        # for websocket
        proxy_http_version 1.1;
{% endif %}
{% if item.key == 'cockpit' or item.value.proto == 'http' %}
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
{% endif %}
{% if item.key == 'guac' %}
        proxy_buffering off;
        proxy_read_timeout 300s;
{% endif %}
{% if item.key != 'guac' %}
        proxy_ssl_verify off;
{% endif %}

    }
{% endif %}

}
