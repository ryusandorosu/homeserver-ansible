[Unit]
Description=Send Telegram notification on shutdown before mihomo proxy container stops
DefaultDependencies=no
Before=shutdown.target reboot.target halt.target
Before=docker.service
Requires=network-online.target
After=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/telegram.sh "🔴 nuc-server shutting down with docker" status "$0"
TimeoutStartSec=60

[Install]
WantedBy=halt.target reboot.target shutdown.target
