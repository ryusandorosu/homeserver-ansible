#!/bin/bash

jail_name="$1"
banned_ip="$2"
logpath="$3"
bantime="$4"
failures="$5"
ipfailures="$6"
ipjailfailures="$7"

grep -m 20 -wF $banned_ip $logpath | grep "Restore Ban" | exit 0

MESSAGE="[Fail2Ban] <b>$jail_name</b>: banned $banned_ip from $(hostname) for <b>$bantime</b>
failures: $failures / ipfailures: $ipfailures / ipjailfailures: $ipjailfailures
<pre>$(curl -s http://ip-api.com/json/$banned_ip | jq)</pre>
<pre>$(grep -m 20 -wF $banned_ip $logpath | grep -v " sudo: " | tail -n 20)</pre>"

/usr/local/bin/tgbot_notify.sh "$MESSAGE"
