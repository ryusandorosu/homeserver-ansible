#!/bin/bash
. {{ watcher_scripts_includes }}/geo-get-json.sh
jail_name="$1"
banned_ip="$2"
logpath="$3"
bantime="$4"
failures="$5"
ipfailures="$6"
ipjailfailures="$7"

loglines=20
if grep -m $loglines -awF $banned_ip {{ f2b_log }} | grep -aE "Restore Ban|already banned"; then exit 0; fi

BANTIME=" $(date -d@$bantime -u +%_H | sed 's/\ //') hours"
(( $bantime >= 86400 )) && BANTIME=" $(date -d@$bantime -u +%_d | sed 's/\ //') days"
(( $bantime >= 2678400 )) && BANTIME=" $(date -d@$bantime -u +%_d | sed 's/\ //') months"
[[ "$BANTIME" =~ ^\ 1\ (hours|days|months)$ ]] && BANTIME=${BANTIME%s}
(( $bantime == -1 )) && BANTIME="ever"

geojson="$(get_ip_geo $banned_ip)"
country="$(echo "$geojson" | jq -r .country)"
logtext="$(grep -m $loglines -awF $banned_ip $logpath | tail -n $loglines)"

EVENT=$(jq -nc \
{% for jq, value in f2b_event_labels.items() %}
  --arg {{ jq }} "${{ value.bash }}" \
{% endfor %}
'{
{% for json, value in f2b_event_labels.items() %}
  {{ json }}:${{ json }}{% if not loop.last %},
{% endif %}
{% endfor %}

}')

[[ -z "{{ custom_logs.fail2ban }}" ]] && touch {{ custom_logs.fail2ban }}
echo "$EVENT" >> {{ custom_logs.fail2ban }}

urlencode() { jq -nr --arg v "$1" '$v|@uri'; }
GRAFANA+="https://grafana.{{ domain }}/"
GRAFANA+="d/{{ f2b_event_dashboard.uid }}/"
GRAFANA+="?orgId=1&from=now-{{ f2b_event_dashboard.showtime }}&to=now&timezone=browser"
{% for label, value in f2b_event_labels.items() if value.label is defined %}
GRAFANA+="&var-{{ label }}=${{ value.bash }}"
{% endfor %}
GRAFANA="$(urlencode "$GRAFANA")"

MESSAGE="[Fail2Ban] <b>$jail_name</b>: banned <code>$banned_ip</code> from $(hostname) for<b>$BANTIME</b>
failures: $failures | ipfailures: $ipfailures
<pre>$(echo "$geojson" | jq)</pre>
matching logs: <a href=\"$GRAFANA\">grafana dashboard</a>"

{{ telegram_script }} "$MESSAGE" alert "$0" &
disown
