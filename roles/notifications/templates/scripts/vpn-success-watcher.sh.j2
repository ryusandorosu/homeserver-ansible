#!/bin/bash
. {{ watcher_scripts_includes }}/geo-include.sh

declare -A new_handshake
[[ ! -f {{ custom_logs.wireguard }} ]] && touch {{ custom_logs.wireguard }}

while true; do
while read -r PUBKEY PSK ENDPOINT ALLOWED EPOCH RX TX KEEPALIVE; do

  if [[ "$EPOCH" == "0" ]]; then
    new_handshake[$PUBKEY]=1
    continue
  fi

  if [[ "${new_handshake[$PUBKEY]}" == "1" ]]; then

    ip="${ENDPOINT%:*}"
    port="${ENDPOINT#*:}"
    vpn_ip="${ALLOWED%%/*}"
    device_name="${vpn_peer_names[$PUBKEY]}"
    logline="$(jq -nc \
{% for jq, value in vpn_watcher_labels.items() %}
      {% if value.json is defined %}--argjson{% else %}--arg{% endif %} {{ jq }} "${{ value.bash }}" \
{% endfor %}
      '{
{% for json, value in vpn_watcher_labels.items() %}
        {{ json }}:${{ json }}{% if not loop.last %},
{% endif %}
{% endfor %}

      }'
    )"

    common_message_init VPN "$PUBKEY" "$device_name"
    logshow="$(jq -r 'del(.geoip)' <<< "$logline")"
    generate_geo_message "$ip" "{{ custom_logs.wireguard }}" "$PUBKEY" "$device_name" "$vpn_ip" "$logshow"

    {{ telegram_script }} "$MESSAGE" status "$0"
    echo "$logline" >> {{ custom_logs.wireguard }}

    new_handshake[$PUBKEY]=0

  fi

done < <(wg show {{ wireguard_interface }} dump | tail -n +2)

sleep 10
done
