#!/bin/bash
. /usr/local/bin/get_ip_geo.sh

declare -A peer_names
{% for peer in wireguard_peers %}
peer_names["{{ peer.public_key }}"]="{{ wireguard_devices[peer.device].name }}"
{% endfor %}

allowed_countries=(
{% for country in allowed_countries %}
  "{{ country }}"
{% endfor %}
)
allowed_regions=(
{% for region in allowed_regions %}
  "{{ region }}"
{% endfor %}
)
allowed_asn=(
{% for asn in allowed_asn %}
  "{{ asn }}"
{% endfor %}
)
not_allowed_flag=false

declare -A new_handshake

while true; do
while read -r PUBKEY PSK ENDPOINT ALLOWED EPOCH RX TX KEEPALIVE; do

if [[ "$EPOCH" == "0" ]]; then
  new_handshake[$PUBKEY]=1
  continue
fi

if [[ "${new_handshake[$PUBKEY]}" == "1" ]]; then

ip="${ENDPOINT%:*}"
port="${ENDPOINT#*:}"
vpn_ip="${ALLOWED%%/*}"
device_name="${peer_names[$PUBKEY]}"

ip_info="$(get_ip_geo $ip)"
country=$(echo "$ip_info" | jq -r .country)
region=$(echo "$ip_info" | jq -r .regionName)
city=$(echo "$ip_info" | jq -r .city)
timezone=$(echo "$ip_info" | jq -r .timezone)
asn="$(echo "$ip_info" | jq -r .as)"
lat=$(echo "$ip_info" | jq -r .lat)
lon=$(echo "$ip_info" | jq -r .lon)

if [[ -z "$device_name" ]]; then
MESSAGE="🚨 UNKNOWN PEER CONNECTED: <code>$PUBKEY</code>
"; else
MESSAGE="🔐 VPN connection success
"; fi

MESSAGE+="From: <code>$ip</code>
Device: <b>$device_name</b> as <code>$vpn_ip</code>
<pre>$(echo "$ip_info" | jq)</pre>
Location: <a href='https://2gis.ru/geo/$lon%2C$lat'>2GIS</a> | <a href='https://maps.google.com/?q=$lat,$lon'>Google Maps</a>
"

if [[ ! " ${allowed_countries[*]} " =~ " ${country} " ]]; then
MESSAGE+="⚠️ VPN connection from the different country
"; not_allowed_flag=true; fi
if [[ ! " ${allowed_regions[*]} " =~ " ${region} " ]]; then
MESSAGE+="⚠️ VPN connection from the different region
"; not_allowed_flag=true; fi
if [[ ! " ${allowed_asn[*]} " =~ " ${asn} " ]]; then
MESSAGE+="⚠️ VPN connection from the different ASN
"; not_allowed_flag=true; fi

if [[ -f {{ wireguard_connections_log }} ]]; then
prev_ip=$(grep "$PUBKEY" {{ wireguard_connections_log }} | tail -n1 | awk '{print $3}' | cut -d: -f1 )
fi

if [[ -n "$prev_ip" && "$prev_ip" != "$ip" ]]; then
prev_ip_info="$(get_ip_geo $prev_ip)"
prev_asn="$(echo "$ip_info" | jq -r .as)"
prev_lat=$(echo "$prev_ip_info" | jq -r .lat)
prev_lon=$(echo "$prev_ip_info" | jq -r .lon)

if [[ "$not_allowed_flag" == false ]]; then
[[ "$prev_asn" != "$asn" ]] && MESSAGE+="ASN changed
"
MESSAGE+="VPN connection from different IP
Previous IP: <code>$prev_ip</code>
"
elif [[ "$not_allowed_flag" == true ]]; then
[[ "$prev_asn" != "$asn" ]] && MESSAGE+="⚠️ ASN changed
"
MESSAGE+="⚠️ VPN connection from different IP
Previous IP: <code>$prev_ip</code>
<pre>$(echo "$prev_ip_info" | jq)</pre>
Previous location: <a href='https://2gis.ru/geo/$prev_lon%2C$prev_lat'>2GIS</a> | <a href='https://maps.google.com/?q=$prev_lat,$prev_lon'>Google Maps</a>
"; fi

fi

/usr/local/bin/tgbot_notify.sh "$MESSAGE"

if [[ "$ip" != "{{ home_ip }}" ]]; then
[[ -z {{ wireguard_connections_log }} ]] && touch {{ wireguard_connections_log }}
echo "$(date --rfc-3339=seconds) $ENDPOINT \"$device_name\" $PUBKEY $vpn_ip $lat,$lon \"$country\" \"$region\" \"$city\" $timezone \"$asn\"" >> {{ wireguard_connections_log }}
fi

new_handshake[$PUBKEY]=0
fi
done < <(wg show {{ wireguard_interface }} dump | tail -n +2)

sleep 10
done
