#!/bin/bash

TYPE=$2
if [[ "$TYPE" == alert ]]; then
  TOKEN="{{ vault_telegram_alert_bot_token }}"
elif [[ "$TYPE" == status ]]; then
  TOKEN="{{ vault_telegram_status_bot_token }}"
else
  echo "usage: $(basename $0) \"message\" alert|status \"\$0\""
  exit 1
fi

CALLER="$3"

PARSE_MODE=$4
[[ -z "$4" ]] && PARSE_MODE=HTML

if [[ "$PARSE_MODE" == HTML ]]; then
MESSAGE=$(
  printf "%s" "$1"
)
elif [[ "$PARSE_MODE" == Markdown* ]]; then
MESSAGE=$(
  printf "$1" | \
  sed 's/[_*[\]()~`>#+-=|{}.!]/\\&/g'
)
fi

MAX_RETRIES=15
RETRY_DELAY=2

addline() {
  [[ -z $2 ]] && touch $2
  echo "$1" >> $2
}

for ((i=1; i<=MAX_RETRIES; i++)); do
  response=$(
	curl -S \
    --proxy "socks5h://{{ localhost }}:{{ socks5_port }}" \
    -X POST "https://api.telegram.org/bot$TOKEN/sendMessage" \
    -d chat_id="{{ vault_telegram_user_chat_id }}" \
    -d text="${MESSAGE}" \
    -d parse_mode="$PARSE_MODE"
  )

  response_ok=$(echo $response | jq -r .ok)
  logline=$(jq -nc \
{% for jq, value in tg_message_labels.items() %}
    {% if jq == 'response' %}--argjson{% else %}--arg{% endif %} {{ jq }} "${{ value.bash }}" \
{% endfor %}
  '{
{% for json, value in tg_message_labels.items() %}
    {{ json }}:${{ json }}{% if not loop.last %},
{% endif %}
{% endfor %}

  }')

  if [[ $response_ok = true ]]; then
    addline "$logline" {{ custom_logs.telegram.success }}
    exit 0
  fi

  echo "$response"
  addline "$logline" {{ custom_logs.telegram.error }}

  sleep $RETRY_DELAY
done

exit 1
