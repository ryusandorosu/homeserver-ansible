#!/bin/bash

TYPE=$2
if [[ "$TYPE" == alert ]]; then
  TOKEN="{{ vault_telegram_alert_bot_token }}"
elif [[ "$TYPE" == status ]]; then
  TOKEN="{{ vault_telegram_status_bot_token }}"
else
  echo "usage: $(basename $0) \"message\" alert|status \"\$0\""
  exit 1
fi

CALLER="$3"

PARSE_MODE=$4
[[ -z "$4" ]] && PARSE_MODE=HTML

if [[ "$PARSE_MODE" == HTML ]]; then
MESSAGE=$(
  printf "%s" "$1"
)
elif [[ "$PARSE_MODE" == Markdown* ]]; then
MESSAGE=$(
  printf "$1" | \
  sed 's/[_*[\]()~`>#+-=|{}.!]/\\&/g'
)
fi

MAX_RETRIES=3
RETRY_DELAY=15

addline() {
  [[ ! -f "$2" ]] && touch $2
  echo "$1" >> $2
}

#    --show-error \
#    --verbose \
#    --connect-timeout $RETRY_DELAY \
for ((i=1; i<=MAX_RETRIES; i++)); do
  response="$(curl \
    --silent \
    --write-out "%{json}\n" \
    --proxy "socks5h://{{ localhost }}:{{ socks5_port }}" \
    --request POST "https://api.telegram.org/bot$TOKEN/sendMessage" \
    --data chat_id="{{ vault_telegram_user_chat_id }}" \
    --data text="${MESSAGE}" \
    --data parse_mode="$PARSE_MODE" \
    2>&1
  )"

  api_response="$(
    echo "$response" \
    | grep -oP '{\"ok\":\w+,\"result\":{.*}}'
  )"
  curl_response="$(
    echo "$response" \
    | grep -oP '{\"certs\":.*}' \
    | jq -r 'if .certs then del(.certs) else . end'
  )"
  if [[ -n "$api_response" ]]; then
    response_ok="$(jq -r '.ok' <<< "$api_response")" 
    response_code="$(jq -r '.error_code' <<< "$api_response")"
  else
    api_response="null"
    response_ok="false"
    response_code="$(jq -r '.exitcode' <<< "$curl_response")"
  fi
  if [[ "$response_code" == null ]]; then
    response_code="$(jq -r '.response_code' <<< "$curl_response")" #.http_code is equivalent
  fi

{# #ledebug
{% for jq, value in tg_message_labels.items() %}
    echo "{% if value.json is defined %}--argjson{% else %}--arg{% endif %} {{ jq }} ${{ value.bash }}"
{% endfor %} #}

  logline="$(jq -nc \
{% for jq, value in tg_message_labels.items() %}
    {% if value.json is defined %}--argjson{% else %}--arg{% endif %} {{ jq }} "${{ value.bash }}" \
{% endfor %}
    '{
{% for json, value in tg_message_labels.items() %}
      {{ json }}:${{ json }}{% if not loop.last %},
{% endif %}
{% endfor %}

    }'
  )"

  if [[ $response_ok == true ]]; then
    addline "$logline" {{ custom_logs.telegram.success }}
    exit 0
  else
    echo "$response"
    addline "$logline" {{ custom_logs.telegram.error }}
  fi

  sleep $RETRY_DELAY
done

exit 1
