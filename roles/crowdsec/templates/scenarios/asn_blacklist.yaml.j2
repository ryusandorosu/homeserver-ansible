type: trigger
name: custom/asn-blacklist
description: "Detect traffic from blacklisted ASN"

filter: |
  evt.Meta.ASNumber in {{ blacklist_asn_ids | map('string') | to_json }}
{% for name in blacklist_asn_names %}
  or evt.Meta.ASName contains "{{ name }}"
{% endfor %}

groupby: evt.Meta.source_ip

blackhole: 1m
reprocess: false

labels:
  service: any
  confidence: 3
  spoofable: 0
  remediation: true
