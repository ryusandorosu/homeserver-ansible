networks:
  monitoring:
    external: true

services:
  node_exporter:
    image: prom/node-exporter:latest
    container_name: {{ docker.node_exporter }}
    restart: unless-stopped
    network_mode: host
    pid: host
    volumes:
      - /:/host:ro,rslave
    command:
      - '--path.rootfs=/host'

  prometheus:
    image: prom/prometheus:latest
    container_name: {{ docker.prometheus }}
    restart: unless-stopped
    user: "65534:65534"
    volumes:
      - {{ prometheus_config_dir }}/prometheus.yml:{{ prometheus_container_config_dir }}/prometheus.yml
      - {{ prometheus_data_dir }}:{{ prometheus_container_data_dir }}
    ports:
      - "{{ prometheus_port }}:{{ const_prometheus_port }}"
    command:
      - '--config.file={{ prometheus_container_config_dir }}/prometheus.yml'
      - '--web.external-url=https://prometheus.{{ domain }}'
    networks:
      - monitoring
