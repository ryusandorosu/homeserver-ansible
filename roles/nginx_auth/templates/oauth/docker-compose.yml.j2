services:
  oauth2-proxy:
    image: quay.io/oauth2-proxy/oauth2-proxy:latest
    container_name: {{ docker.oauth2proxy }}
    restart: unless-stopped
    volumes:
      - {{ oauth_config }}:{{ oauth_config }}
    command:
      - --config={{ oauth_config }}
    ports:
      - "{{ localhost }}:{{ oauthproxy_port }}:{{ oauthproxy_port }}"
