require("mason-lspconfig").setup({
  ensure_installed = {
{% for language_server in mason_lspconfig %}
    "{{ language_server }}ls",
{% endfor %}
{% for language_server in mason_configs %}
    "{{ language_server }}",
{% endfor %}
  }
})

{% for language_server in mason_lspconfig %}
vim.lsp.enable("{{ language_server }}ls")
{% endfor %}
{% for language_server in mason_configs %}
vim.lsp.enable("{{ language_server }}")
{% endfor %}
