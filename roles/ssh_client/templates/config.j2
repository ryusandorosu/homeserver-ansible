{% for key, value in ssh_hosts.items() %}
Host {{ key }}
    HostName {{ value.hostname }}
    User {{ value.user }}
    IdentityFile ~/.ssh/{{ value.identity }}
{% if value.port is defined %}
    Port {{ value.port }}
{% endif %}
{% if value.options is defined %}
{% for item in value.options %}
    {{ item }}
{% endfor %}
{% endif %}

{% endfor %}
