flush ruleset

table inet filter {

{% for key, set in inet_filter_sets.items() %}
    set {{ key }} {
{% for key, value in set.items() %}
{% if value is string %}
        {{ key }} {{ value }}
{% else %}
        {{ key }} {{ value | join(',') }}
{% endif %}
{% endfor %}
{% if key == 'whitelist' %}
        elements = { {{ firewall_ip_whitelist | join(', ') }} }
{% endif %}
    }
{% endfor %}

    chain input {
        type filter hook input priority 0;
        policy drop;

        ct state established,related accept
        iif lo accept

        ip saddr @whitelist log prefix "{{ nft_log_prefix }}chain=input action=accept: " accept
        ip saddr @whitelist accept
{% for key, set in inet_filter_sets.items() if key != "whitelist" %}
        ip saddr @{{ key }} drop
{% endfor %}
{% for port in monitoring_exporter_ports %}
        ip saddr {{ docker_monitoring_network }} tcp dport {{ port }} accept
{% endfor %}
        ip saddr {{ docker_network }} ip daddr {{ home_network }} accept
        ip saddr {{ lan_ip.router }} ip daddr 224.0.0.1 accept
{# ip saddr fe80:0000:0000:0000:da0d:17ff:fedf:d182 ip daddr ff02:0000:0000:0000:0000:0000:0000:0001 accept #}
{# icmpv6 type { 133, 134, 135, 136 } accept #}
        icmpv6 type { 130, 134 } accept

{# tcp dport {{ sshd_port }} ct state new limit rate 10/minute burst 20 packets accept #}
        iif "{{ wireguard_interface }}" tcp dport {{ sshd_port }} ct state new accept
{% for port in firewall_tcp_ports %}{% if port != sshd_port %}
        tcp dport {{ port }} accept
{% endif %}{% endfor %}

{% for port in firewall_udp_ports %}
        udp dport {{ port }} accept
{% endfor %}

        iif "{{ wireguard_interface }}" accept
        {# iif "{{ wireguard_interface }}" tcp dport { {{ firewall_lan_tcp_ports | join(', ') }} } accept
        iif "{{ wireguard_interface }}" udp dport { {{ firewall_lan_udp_ports | join(', ') }} } accept #}
        iif "{{ lan_interface }}" tcp dport { {{ firewall_lan_tcp_ports | join(', ') }} } accept
        iif "{{ lan_interface }}" udp dport { {{ firewall_lan_udp_ports | join(', ') }} } accept
{% for interface in docker_interfaces %}
        iifname "{{ interface }}" udp dport { {{ firewall_lan_udp_ports | join(', ') }} } accept
{% endfor %}

        {# tcp dport { 137, 138, 139, 445 } log prefix "{{ nft_log_prefix }}chain=input action=SMB_DEBUG: " #}
        limit rate 5/minute log prefix "{{ nft_log_prefix }}chain=input action=drop: " flags all counter drop
    }

    chain forward {
        type filter hook forward priority 0;
        policy drop;

{# tcp flags syn tcp option maxseg size set rt mtu #}
        {# tcp flags syn tcp option maxseg size set 1360 #}
        ct state established,related accept

{% for interface in docker_interfaces %}
        iifname "{{ interface }}" accept
        oifname "{{ interface }}" accept
{% endfor %}

        iif "{{ wireguard_interface }}" oif "{{ lan_interface }}" accept
        iif "{{ wireguard_interface }}" oif "{{ wireguard_interface }}" accept

{% for allowed in nginx_allowed %}
{% for site in nginx_sni %}
        ip daddr {{ site.host }} tcp dport {{ site.port }} ip saddr {{ allowed }} accept
{% endfor %}
{% endfor %}
{% for site in nginx_sni %}
        ip daddr {{ site.host }} tcp dport {{ site.port }} drop
{% endfor %}
        limit rate 5/minute log prefix "{{ nft_log_prefix }}chain=forward action=drop: " flags all counter drop
    }

    chain output {
        type filter hook output priority 0;
        policy accept;
    }
}

table ip nat {
    chain postrouting {
        type nat hook postrouting priority 100;
        oifname "{{ lan_interface }}" ip saddr {{ wireguard_network }} masquerade
        oifname "{{ lan_interface }}" ip saddr {{ docker_network }} masquerade
    }
}
