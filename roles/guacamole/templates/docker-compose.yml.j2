networks:
  guac_net:
    external: true

services:
  guacd:
    image: guacamole/guacd:1.5.5
    container_name: {{ docker.guacd }}
    restart: unless-stopped
    networks:
      - guac_net

  postgres:
    image: postgres:16
    container_name: {{ docker.postgres }}
    restart: unless-stopped
    environment:
      POSTGRES_DB: guacamole_db
      POSTGRES_USER: guacamole_user
      POSTGRES_PASSWORD: {{ vault_guacamole_db }}
    volumes:
      - "{{ guacamole_dir }}/init:/docker-entrypoint-initdb.d:ro"
      - pgdata:/var/lib/postgresql/data
    networks:
      - guac_net

  guacamole:
    image: guacamole/guacamole:1.5.5
    container_name: {{ docker.guacamole }}
    restart: unless-stopped
    environment:
      GUACD_HOSTNAME: guacd
      GUACD_PORT: 4822
      POSTGRESQL_HOSTNAME: postgres
      POSTGRESQL_DATABASE: guacamole_db
      POSTGRESQL_USER: guacamole_user
      POSTGRESQL_PASSWORD: {{ vault_guacamole_db }}
    ports:
      - "{{ localhost }}:{{ guacamole_port }}:{{ internal_port.guacamole }}"
    depends_on:
      - guacd
      - postgres
    networks:
      - guac_net
{% if guacamole_extensions | default([]) | length > 0 %}
    volumes:
      - "{{ guacamole_dir }}/extensions:/etc/guacamole/extensions:ro"
{% endif %}

volumes:
  pgdata:
