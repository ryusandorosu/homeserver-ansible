services:
  mihomo:
    image: metacubex/mihomo:latest
    container_name: {{ docker.mihomo }}
    restart: unless-stopped
    volumes:
      - "{{ clash_config_dir }}:/root/.config/mihomo"
    healthcheck:
      test: ["CMD", "nc", "-z", "{{ localhost }}", "{{ socks5_port }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    network_mode: host
    stop_grace_period: 30s

{% if clash_web_interface == 'yacd' %}
  yacd:
    image: haishanh/yacd
    container_name: {{ docker.mihomo_dashboard }}
    restart: unless-stopped
    ports:
      - "{{ yacd_port }}:{{ http_port }}"
    environment:
      - BACKEND=http://{{ lan_ip.server }}:{{ clash_web_port }}
{% elif clash_web_interface == 'metacubexd' %}
  metacubexd:
    image: ghcr.io/metacubex/metacubexd:latest
    container_name: {{ docker.mihomo_dashboard }}
    restart: unless-stopped
    ports:
      - "{{ metacubexd_port }}:{{ http_port }}"
    environment:
      - DEFAULT_BACKEND_URL=http://{{ lan_ip.server }}:{{ clash_web_port }}
{% endif %}
