server:
  http_listen_port: {{ promtail_port }}

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ loki_container }}:{{ loki_port }}/loki/api/v1/push

scrape_configs:

{% for job in promtail_scrape_configs %}
  - job_name: {{ job.name }}
    static_configs:
      - targets:
          - localhost
        labels:
          job: {{ job.name }}
          host: {{ inventory_hostname }}
          __path__: {{ job.path }}
{% endfor %}
