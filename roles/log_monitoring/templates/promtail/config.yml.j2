server:
  http_listen_port: {{ promtail_port }}

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ docker.loki }}:{{ loki_port }}/loki/api/v1/push

scrape_configs:
{% for key, job in promtail_logs.items() %}
  - job_name: {{ job.name }}
    static_configs:
      - targets:
          - localhost
        labels:
          job: {{ job.name }}
          host: {{ inventory_hostname }}
          __path__: {{ job.path }}
{% if job.pipeline is defined and job.pipeline == 'nginx' %}
    pipeline_stages:
      - regex:
          source: filename
          expression: '/var/log/nginx/(?P<vhost>[^_]+)_access.log'
      - labels:
          vhost:

      - regex:
          expression: '^(?P<ip>\S+) - (?P<user>\S+) \[(?P<time>.+)\] "(?P<method>\S+) (?P<uri>\S+) (?P<protocol>[^"]+)" (?P<status>\d+) (?P<size>\d+) "(?P<referrer>[^"]*)" "(?P<agent>[^"]*)" (?P<request_time>\S+)'
      - labels:
          status:
          method:
          uri:
          ip:

      - template:
          source: uri
          template: {% raw %}'{{ regexReplaceAll "\\?.*" .Value "" }}'
{% endraw %}

      - template:
          source: request_time
          template: {% raw %}'{{ .Value }}'
{% endraw %}

      - geoip:
          db: {{ container_geoip_plugin }}
          source: ip
          db_type: city
      - labeldrop:
          - geoip_city_name
          - geoip_continent_code
          - geoip_continent_name
          - geoip_location_latitude
          - geoip_location_longitude
          - geoip_postal_code
          - geoip_subdivision_code
          - geoip_subdivision_name
          - geoip_timezone
      - labels:
          geoip_country_name:
{% endif %}

{% endfor %}

  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
    relabel_configs:
      - source_labels: ['__meta_docker_container_name']
        target_label: container
      - source_labels: ['__meta_docker_container_log_stream']
        target_label: stream
      - source_labels: ['__meta_docker_container_label_com_docker_compose_service']
        target_label: service
    pipeline_stages:
      - docker: {}

  - job_name: systemd
    journal:
      max_age: 24h
      labels:
        job: systemd
        host: {{ inventory_hostname }}
    relabel_configs:
      - source_labels: ['__journal__systemd_unit']
        target_label: unit
